    function renderBar(level) {
        var total = 20;
        var filled = Math.round((level / 100) * total);
        var empty = total - filled;
        var bar = '';
        for (var i = 0; i < filled; i++) bar += '█';
        for (var j = 0; j < empty; j++) bar += '░';
        return bar;
    }

