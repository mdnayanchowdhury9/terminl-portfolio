    function handleEasterEgg(raw) {
        var lower = raw.toLowerCase().trim();

        if (lower === 'sudo' || lower.indexOf('sudo ') === 0) {
            printHTML('  <span class="red">Nice try! This is a read-only filesystem.</span>');
            return true;
        }

        if (lower === 'rm -rf /' || lower === 'rm -rf *') {
            printHTML('  <span class="red">Permission denied. Nice try though.</span>');
            return true;
        }

        if (lower === 'vim' || lower === 'vi' || lower === 'nvim') {
            printHTML('  <span class="amber">How do you exit vim? Nobody knows...</span>');
            printHTML('  <span class="muted">Hint: :q! \u2014 or just close the tab</span>');
            return true;
        }

        if (lower === 'exit' || lower === 'quit') {
            printHTML('  <span class="red">There is no escape from the portfolio.</span>');
            printHTML('  <span class="muted">You can check out any time you like, but you can never leave.</span>');
            return true;
        }

        if (lower === 'hack' || lower === 'hackerman') {
            printHTML('  <span class="green">Access granted... just kidding.</span>');
            return true;
        }

        if (lower === 'hello' || lower === 'hi' || lower === 'hey') {
            printHTML('  <span class="cyan">Hey there! Welcome to my portfolio terminal.</span>');
            printHTML('  <span class="muted">Type \'help\' to see what I can do.</span>');
            return true;
        }

        if (lower === 'cowsay') {
            var msg = 'Moo! Hire this developer!';
            var border = '';
            for (var b = 0; b < msg.length + 2; b++) border += '\u2500';
            blank();
            print('  \u250C' + border + '\u2510');
            print('  \u2502 ' + msg + ' \u2502');
            print('  \u2514' + border + '\u2518');
            print('          \\   ^__^');
            print('           \\  (oo)\\_______');
            print('              (__)\\       )\\/\\');
            print('                  ||----w |');
            print('                  ||     ||');
            blank();
            return true;
        }

        return false;
    }

    /* ═══════════════════════════════════════════════
       COMMAND ROUTER
       ═══════════════════════════════════════════════ */

    var COMMANDS = {
        help:       { desc: 'Show available commands',        fn: cmdHelp },
        about:      { desc: 'About me',                       fn: cmdAbout },
        skills:     { desc: 'Technical skills',               fn: cmdSkills },
        projects:   { desc: 'Featured projects',              fn: cmdProjects },
        experience: { desc: 'Work experience',                fn: cmdExperience },
        education:  { desc: 'Education background',           fn: cmdEducation },
        contact:    { desc: 'Contact information',            fn: cmdContact },
        resume:     { desc: 'Download resume',                fn: cmdResume },
        clear:      { desc: 'Clear terminal',                 fn: cmdClear },
        whoami:     { desc: 'Who am I?',                      fn: cmdWhoami },
        date:       { desc: 'Current date and time',          fn: cmdDate },
        history:    { desc: 'Command history',                fn: cmdHistoryCmd },
        neofetch:   { desc: 'System information',             fn: cmdNeofetch },
        fortune:    { desc: 'Random developer quote',         fn: cmdFortune },
        theme:      { desc: 'Switch theme (green/amber/cyan)',fn: cmdTheme }
    };

    function processCommand(raw) {
        var trimmed = raw.trim();

        addCommandToOutput(trimmed);

        if (!trimmed) {
            scrollToBottom();
            return;
        }

        cmdHistory.push(trimmed);
        historyIdx = cmdHistory.length;

        if (handleEasterEgg(trimmed)) {
            scrollToBottom();
            return;
        }

        var parts = trimmed.split(/\s+/);
        var cmd = parts[0].toLowerCase();
        var args = parts.slice(1);

        if (COMMANDS[cmd]) {
            COMMANDS[cmd].fn(args);
        } else {
            printHTML('  <span class="red">Command not found: ' + escapeHTML(cmd) + '</span>');
            printHTML('  <span class="muted">Type \'help\' to see available commands.</span>');
        }

        scrollToBottom();
    }

    /* ═══════════════════════════════════════════════
       TAB COMPLETION
       ═══════════════════════════════════════════════ */

    function tabComplete() {
        var val = inputEl.value.trim().toLowerCase();
        if (!val) return;

        var allCmds = Object.keys(COMMANDS).concat([
            'sudo', 'vim', 'vi', 'nvim', 'exit', 'quit',
            'hack', 'hackerman', 'hello', 'hi', 'hey',
            'cowsay', 'rm'
        ]);

        var matches = [];
        for (var i = 0; i < allCmds.length; i++) {
            if (allCmds[i].indexOf(val) === 0) {
                matches.push(allCmds[i]);
            }
        }

        if (matches.length === 1) {
            inputEl.value = matches[0] + ' ';
        } else if (matches.length > 1) {
            // Find longest common prefix
            var common = matches[0];
            for (var j = 1; j < matches.length; j++) {
                while (matches[j].indexOf(common) !== 0) {
                    common = common.slice(0, -1);
                }
            }
            inputEl.value = common;

            // Show options
            addCommandToOutput(val);
            printHTML('  <span class="muted">' + escapeHTML(matches.join('  ')) + '</span>');
            scrollToBottom();
        }
    }

    /* ═══════════════════════════════════════════════
       BOOT SEQUENCE
       ═══════════════════════════════════════════════ */

    async function boot() {
        var bootLines = [
            { text: '  Booting Terminal Portfolio v2.0...', cls: 'muted', delay: 200 },
            { text: '  Loading kernel modules...',          cls: 'muted', delay: 150 },
            { text: '  [OK] Network interface',             cls: 'green', delay: 120 },
            { text: '  [OK] Display server',                cls: 'green', delay: 100 },
            { text: '  [OK] Terminal emulator',             cls: 'green', delay: 100 },
            { text: '  [OK] Portfolio engine',              cls: 'green', delay: 100 },
            { text: '',                                      cls: '',      delay: 300 }
        ];

        for (var i = 0; i < bootLines.length; i++) {
            var line = bootLines[i];
            print(line.text, line.cls);
            scrollToBottom();
            await sleep(line.delay);
        }

        var artDiv = document.createElement('div');
        artDiv.className = 'ascii-art';
        artDiv.textContent = LOGO;
        outputEl.appendChild(artDiv);
        scrollToBottom();
        await sleep(400);

        blank();
        printHTML('  <span class="green">Welcome to my terminal portfolio!</span>');
        printHTML('  <span class="muted">I\'m ' + escapeHTML(CONFIG.name) + ', a ' + escapeHTML(CONFIG.title) + '.</span>');
        blank();
        printHTML('  <span class="muted">Type</span> <span class="amber">help</span> <span class="muted">to see available commands, or start exploring.</span>');
        blank();
        scrollToBottom();

        booted = true;
        inputLine.classList.add('visible');
        inputEl.focus();
    }

    /* ═══════════════════════════════════════════════
       EVENT LISTENERS
       ═══════════════════════════════════════════════ */

    inputEl.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            var cmd = inputEl.value;
            inputEl.value = '';
            processCommand(cmd);
        }

        if (e.key === 'Tab') {
            e.preventDefault();
            tabComplete();
        }

        if (e.key === 'ArrowUp') {
            e.preventDefault();
            if (cmdHistory.length > 0 && historyIdx > 0) {
                historyIdx--;
                inputEl.value = cmdHistory[historyIdx];
            }
        }

        if (e.key === 'ArrowDown') {
            e.preventDefault();
            if (historyIdx < cmdHistory.length - 1) {
                historyIdx++;
                inputEl.value = cmdHistory[historyIdx];
            } else {
                historyIdx = cmdHistory.length;
                inputEl.value = '';
            }
        }

        if (e.key === 'l' && e.ctrlKey) {
            e.preventDefault();
            cmdClear();
        }

        if (e.key === 'c' && e.ctrlKey && !window.getSelection().toString()) {
            e.preventDefault();
            addCommandToOutput(inputEl.value + '^C');
            inputEl.value = '';
            scrollToBottom();
        }

        if (e.key === 'u' && e.ctrlKey) {
            e.preventDefault();
            inputEl.value = '';
        }
    });

    document.addEventListener('click', function () {
        if (booted) inputEl.focus();
    });

    /* ═══════════════════════════════════════════════
       INIT
       ═══════════════════════════════════════════════ */

    boot();

})();
</script>

