            green: { green: '#00ff41', glow: 'rgba(0,255,65,0.12)', dim: '#1a5c2e' },
            amber: { green: '#ffb000', glow: 'rgba(255,176,0,0.12)', dim: '#5c4a1a' },
            cyan:  { green: '#00d4ff', glow: 'rgba(0,212,255,0.12)', dim: '#1a4a5c' }
        };

        if (!theme || !themes[theme]) {
            blank();
            printHTML('  <span class="muted">Usage: theme &lt;green|amber|cyan&gt;</span>');
            printHTML('  <span class="muted">Current: ' + escapeHTML(getCurrentTheme()) + '</span>');
            blank();
            return;
        }

        var t = themes[theme];
        document.documentElement.style.setProperty('--green', t.green);
        document.documentElement.style.setProperty('--green-glow', t.glow);
        document.documentElement.style.setProperty('--green-dim', t.dim);

        blank();
        printHTML('  <span class="green">Theme switched to ' + escapeHTML(theme) + '</span>');
        blank();
    }

